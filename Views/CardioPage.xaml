<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FitnessQuest.Views.CardioPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FitnessQuest.ViewModels"
    xmlns:models="clr-namespace:FitnessQuest.Models"
    x:Name="Page"
    x:DataType="vm:CardioViewModel"
    Title="Cardio"
    BackgroundColor="{StaticResource AppBg}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="14">

            <!-- Type selector -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="🏃 Löpning" FontSize="13"
                        Command="{Binding SelectTypeCommand}" CommandParameter="{x:Static models:CardioType.Running}"
                        BackgroundColor="{StaticResource Surface}" TextColor="{StaticResource TextMuted}" CornerRadius="14" HeightRequest="60">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedType}" Value="{x:Static models:CardioType.Running}">
                            <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
                            <Setter Property="TextColor" Value="{StaticResource AppBg}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Text="🚴 Cykling" FontSize="13"
                        Command="{Binding SelectTypeCommand}" CommandParameter="{x:Static models:CardioType.Cycling}"
                        BackgroundColor="{StaticResource Surface}" TextColor="{StaticResource TextMuted}" CornerRadius="14" HeightRequest="60">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedType}" Value="{x:Static models:CardioType.Cycling}">
                            <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
                            <Setter Property="TextColor" Value="{StaticResource AppBg}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="2" Text="🚶 Promenad" FontSize="13"
                        Command="{Binding SelectTypeCommand}" CommandParameter="{x:Static models:CardioType.Walking}"
                        BackgroundColor="{StaticResource Surface}" TextColor="{StaticResource TextMuted}" CornerRadius="14" HeightRequest="60">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedType}" Value="{x:Static models:CardioType.Walking}">
                            <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
                            <Setter Property="TextColor" Value="{StaticResource AppBg}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <!-- Inputs -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Distans (km)" Style="{StaticResource Muted}" />
                            <Entry Text="{Binding Distance}" Keyboard="Numeric" Style="{StaticResource FieldEntry}"
                                   FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" Placeholder="0" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Tid (min)" Style="{StaticResource Muted}" />
                            <Entry Text="{Binding Duration}" Keyboard="Numeric" Style="{StaticResource FieldEntry}"
                                   FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" Placeholder="0" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceAlt}" Padding="14,10">
                        <Label Text="Tempo" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding PaceDisplay}" TextColor="{StaticResource AccentGreen}"
                               FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Entry Text="{Binding Notes}" Placeholder="Anteckning (valfritt)" Style="{StaticResource FieldEntry}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="{Binding SaveLabel}" Style="{StaticResource GreenButton}" Command="{Binding SaveCommand}" />
            <Button Text="Avbryt redigering" Command="{Binding CancelEditCommand}" IsVisible="{Binding IsEditing}"
                    BackgroundColor="Transparent" TextColor="{StaticResource TextMuted}" />

            <!-- Total -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding HasHistory}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="🏅 Total distans" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding TotalDistance, StringFormat='{0:0.0} km'}"
                           TextColor="{StaticResource XpGold}" FontSize="20" FontAttributes="Bold" />
                </Grid>
            </Border>

            <!-- History -->
            <Label Text="Tidigare pass" Style="{StaticResource SectionTitle}" />
            <Label Text="Inga pass loggade än – ut och rör på dig! 🏃" Style="{StaticResource Muted}"
                   IsVisible="{Binding HasHistory, Converter={StaticResource InvertedBool}}" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentSessions}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:CardioSession">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.EditSessionCommand, Source={x:Reference Page}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Text="{Binding TypeEmoji}" FontSize="26" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding TypeName}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding DateDisplay}" Style="{StaticResource Muted}" FontSize="11" />
                                    </Grid>
                                    <Label Text="{Binding Summary}" Style="{StaticResource Muted}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2" Text="🗑" FontSize="15" BackgroundColor="Transparent" VerticalOptions="Center"
                                        Command="{Binding BindingContext.DeleteSessionCommand, Source={x:Reference Page}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="12" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
