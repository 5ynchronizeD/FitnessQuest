<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FitnessQuest.Views.ExercisePickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FitnessQuest.ViewModels"
    xmlns:models="clr-namespace:FitnessQuest.Models"
    x:Name="Page"
    x:DataType="vm:ExercisePickerViewModel"
    Title="Välj övning"
    BackgroundColor="{StaticResource AppBg}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12">
        <Entry Grid.Row="0" Text="{Binding Search}" Placeholder="Sök övning eller muskelgrupp..."
               Style="{StaticResource FieldEntry}" Margin="0,0,0,8" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Exercises}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.SelectCommand, Source={x:Reference Page}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                <Label Text="{Binding MuscleGroup}" Style="{StaticResource Muted}" FontSize="11" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding EquipmentLabel}" Style="{StaticResource Muted}" VerticalOptions="Center" FontSize="11" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="＋ Lägg till egen övning" Command="{Binding AddCustomCommand}"
                IsVisible="{Binding CanAddCustom}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0" />
    </Grid>
</ContentPage>
