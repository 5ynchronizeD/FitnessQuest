<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FitnessQuest.Views.NutritionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FitnessQuest.ViewModels"
    xmlns:models="clr-namespace:FitnessQuest.Models"
    x:Name="Page"
    x:DataType="vm:NutritionViewModel"
    Title="Kost"
    BackgroundColor="{StaticResource AppBg}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="14">

            <!-- Calorie summary -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Idag" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding CalorieLabel}" Style="{StaticResource Muted}" />
                    </Grid>
                    <ProgressBar Progress="{Binding CalorieProgress}" ProgressColor="{StaticResource AccentGreen}"
                                 BackgroundColor="{StaticResource SurfaceAlt}" />
                    <Grid ColumnDefinitions="*,*,*">
                        <Label Grid.Column="0" HorizontalOptions="Center" TextColor="{StaticResource ProteinColor}"
                               Text="{Binding TotalProtein, StringFormat='P {0:0} g'}" FontSize="13" FontAttributes="Bold" />
                        <Label Grid.Column="1" HorizontalOptions="Center" TextColor="{StaticResource CarbsColor}"
                               Text="{Binding TotalCarbs, StringFormat='K {0:0} g'}" FontSize="13" FontAttributes="Bold" />
                        <Label Grid.Column="2" HorizontalOptions="Center" TextColor="{StaticResource FatColor}"
                               Text="{Binding TotalFat, StringFormat='F {0:0} g'}" FontSize="13" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Balance suggestion (only shown when useful) -->
            <Border Style="{StaticResource Card}" BackgroundColor="{StaticResource SurfaceAlt}" IsVisible="{Binding HasSuggestion}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Text="{Binding SuggestionText}" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" FontSize="13" />
                    <Button Grid.Column="1" Text="✕" Command="{Binding DismissSuggestionCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource TextMuted}" WidthRequest="40" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Scan + quick log + search -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="📷  Skanna" Style="{StaticResource GreenButton}"
                        Command="{Binding ScanBarcodeCommand}" />
                <Button Grid.Column="1" Text="⚡  Snabblogg" Command="{Binding QuickLogCommand}"
                        BackgroundColor="{StaticResource AccentPrimary}" TextColor="White" FontAttributes="Bold"
                        FontSize="16" CornerRadius="16" HeightRequest="54" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Placeholder="Sök livsmedel..." Text="{Binding SearchQuery}"
                       Style="{StaticResource FieldEntry}" ReturnType="Search"
                       ReturnCommand="{Binding SearchCommand}" />
                <Button Grid.Column="1" Text="Sök" Command="{Binding SearchCommand}"
                        BackgroundColor="{StaticResource AccentPrimary}" TextColor="White"
                        CornerRadius="14" WidthRequest="70" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsSearching}" IsVisible="{Binding IsSearching}"
                               Color="{StaticResource AccentPrimary}" />

            <!-- Search results -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasSearchResults}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Sökträffar" Style="{StaticResource SectionTitle}" />
                    <Button Grid.Column="1" Text="Rensa" Command="{Binding ClearSearchCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource TextMuted}" />
                </Grid>
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SearchResults}" Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:FoodItem">
                            <Border Style="{StaticResource Card}" Padding="14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.SelectFoodCommand, Source={x:Reference Page}}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding DisplayName}" TextColor="{StaticResource TextPrimary}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding MacroSummary}" Style="{StaticResource Muted}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Recent / favourite foods -->
            <Label Text="Senaste &amp; favoriter" Style="{StaticResource SectionTitle}"
                   IsVisible="{Binding HasSearchResults, Converter={StaticResource InvertedBool}}" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentFoods}" Spacing="8"
                                 IsVisible="{Binding HasSearchResults, Converter={StaticResource InvertedBool}}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.SelectFoodCommand, Source={x:Reference Page}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding DisplayName}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                    <Label Text="{Binding MacroSummary}" Style="{StaticResource Muted}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="⭐" FontSize="18" VerticalOptions="Center"
                                       IsVisible="{Binding IsFavorite}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Today's log -->
            <Label Text="Loggat idag" Style="{StaticResource SectionTitle}" />
            <Label Text="Inget loggat än – skanna eller sök för att komma igång! 🍽️"
                   Style="{StaticResource Muted}" IsVisible="{Binding HasEntries, Converter={StaticResource InvertedBool}}" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding TodayEntries}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodLogEntry">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.EditEntryCommand, Source={x:Reference Page}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Text="{Binding MealEmoji}" FontSize="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                                    <Label Style="{StaticResource Muted}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                <Binding Path="MealName" />
                                                <Binding Path="Summary" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>
                                <Button Grid.Column="2" Text="🗑" BackgroundColor="Transparent" FontSize="18"
                                        Command="{Binding BindingContext.DeleteEntryCommand, Source={x:Reference Page}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="12" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
