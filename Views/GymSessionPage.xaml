<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FitnessQuest.Views.GymSessionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FitnessQuest.ViewModels"
    xmlns:models="clr-namespace:FitnessQuest.Models"
    x:Name="Page"
    x:DataType="vm:GymWorkoutViewModel"
    Title="Gym"
    BackgroundColor="{StaticResource AppBg}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="14">

            <!-- Summary -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pass totalt" Style="{StaticResource Muted}" />
                        <Label Text="{Binding TotalWorkouts}" TextColor="{StaticResource AccentPrimary}" FontSize="26" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Volym denna vecka" Style="{StaticResource Muted}" />
                        <Label Text="{Binding VolumeThisWeek, StringFormat='{0:0} kg'}" TextColor="{StaticResource AccentGreen}" FontSize="26" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="＋  Starta nytt pass" Style="{StaticResource PrimaryButton}" Command="{Binding StartWorkoutCommand}" />
            <Button Text="🏋️  Viktkalkylator" Command="{Binding OpenPlateCalculatorCommand}"
                    BackgroundColor="{StaticResource Surface}" TextColor="{StaticResource TextPrimary}" CornerRadius="16" HeightRequest="50" />

            <Label Text="Historik" Style="{StaticResource SectionTitle}" />
            <Label Text="Inga pass loggade än – starta ditt första! 🏋️" Style="{StaticResource Muted}"
                   IsVisible="{Binding HasHistory, Converter={StaticResource InvertedBool}}" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentWorkouts}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Workout">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.EditWorkoutCommand, Source={x:Reference Page}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" FontSize="15" />
                                    <Label Text="{Binding DateDisplay}" Style="{StaticResource Muted}" FontSize="11" />
                                    <Label Style="{StaticResource Muted}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}  ·  ⏱ {1}">
                                                <Binding Path="Summary" />
                                                <Binding Path="DurationDisplay" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="🗑" FontSize="16" BackgroundColor="Transparent" VerticalOptions="Center"
                                        Command="{Binding BindingContext.DeleteWorkoutCommand, Source={x:Reference Page}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="12" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
