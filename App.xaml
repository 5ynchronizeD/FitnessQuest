<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FitnessQuest"
             xmlns:conv="clr-namespace:FitnessQuest.Converters"
             x:Class="FitnessQuest.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <conv:InvertedBoolConverter x:Key="InvertedBool" />
            <conv:IsNotNullConverter x:Key="IsNotNull" />
            <conv:IsNullConverter x:Key="IsNull" />
            <conv:ActivityLevelToSwedishConverter x:Key="ActivitySwedish" />
            <conv:BoolToColorConverter x:Key="UnlockTextColor"
                TrueColor="{StaticResource TextPrimary}"
                FalseColor="{StaticResource TextMuted}" />

            <!-- Card container -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="StrokeShape">
                    <RoundRectangle CornerRadius="20" />
                </Setter>
            </Style>

            <!-- Section heading -->
            <Style x:Key="SectionTitle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="Margin" Value="4,8,4,4" />
            </Style>

            <Style x:Key="Muted" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Primary action button -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HeightRequest" Value="54" />
            </Style>

            <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
                <Setter Property="TextColor" Value="{StaticResource AppBg}" />
            </Style>

            <!-- Text entry on dark surfaces -->
            <Style x:Key="FieldEntry" TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
